{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "colcon: build",
            "type": "shell",
            "command": [
                "source /opt/ros/jazzy/setup.bash;",
                "colcon build",
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "colcon: clean",
            "type": "shell",
            "command": [
                "rm -rf build install log"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
        }
    ]
}
